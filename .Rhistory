install.packages(c("repr", "IRdisplay", "IRkernel"))
IRkernel::installspec()
install.packages("languageserver")
exit
end
q()
cat("===== R SESSION =====\n")
cat("R.home():", R.home(), "\n")
cat("R.version.string:", R.version.string, "\n\n")

cat("===== PATHS =====\n")
cat("Sys.which('R'):", Sys.which("R"), "\n")
cat("Sys.which('jupyter'):", Sys.which("jupyter"), "\n")
cat("PATH:", Sys.getenv("PATH"), "\n\n")

cat("===== PACKAGES =====\n")
pkgs <- c("IRkernel", "repr", "IRdisplay", "languageserver")
for (p in pkgs) {
  cat("Package", p, ": ")
  if (requireNamespace(p, quietly = TRUE)) {
    cat(as.character(utils::packageVersion(p)), "\n")
  } else {
    cat("NOT INSTALLED\n")
  }
}
cat("\n")

cat("===== JUPYTER FROM R =====\n")
tryCatch({
  print(system2("jupyter", c("--version"), stdout = TRUE, stderr = TRUE))
}, error = function(e) {
  cat("ERROR calling jupyter --version:", conditionMessage(e), "\n")
})
cat("\n")

cat("===== IRKERNEL =====\n")
if (requireNamespace("IRkernel", quietly = TRUE)) {
  print(IRkernel::installspec)
} else {
  cat("IRkernel not installed, cannot inspect installspec()\n")
}
cat("\n")

cat("===== USER LIB PATHS =====\n")
print(.libPaths())
q()
